// 00_cleanup_shared_objects.dos
// 目标：删除历史共享内存对象，确保后续流程不依赖 shared table

sharedNames = [`pricingBondDesc, `pricingInstrumentStore, `pricingResult, `pricingMarketCurve, `pricingMarketQuote]

for(n in sharedNames){
    if(exists(string(n))){
        undef(n, SHARED)
    }
}

print("Shared objects cleaned.")
"DONE"
