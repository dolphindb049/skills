//prepareEP(m_aCompustat, SignalMasterTable, 1986.03M, 2010.12M)




def prepareEarnSupBig(SignalMasterTable, m_QCompustat, startTime, endTime){
    data1 = select permno, gvkey, time_avail_m from SignalMasterTable where !isNull(gvkey)
    merged_data = select data1.*, m_QCompustat.epspxq from data1 inner join m_QCompustat on data1.gvkey = m_QCompustat.gvkey and data1.time_avail_m = m_QCompustat.time_avail_m
    merged_data = select *, epspxq - move(merged_data.epspxq,12) as GrTemp from merged_data context by permno
    for (n in 1:9) {
        str = "temp" + string(3*n)
        merged_data = select *, move(merged_data.GrTemp,3*n) as cg from merged_data context by permno
        rename!(merged_data,`cg,str)
    }
    merged_data =  select *, rowAvg(temp3,temp6,temp9,temp12,temp15,temp18,temp21,temp24) as Drift from merged_data
    merged_data = select *, epspxq - move(merged_data.epspxq,12) - Drift as EarningsSurprise from merged_data context by permno
    for (n in 1:9) {
        dropColumns!(merged_data, "temp" + string(3*n))
    }
    for (n in 1:9) {
        str = "temp" + string(3*n)
        merged_data = select *, move(merged_data.EarningsSurprise,3*n) as cg from merged_data context by permno
        rename!(merged_data,`cg,str)
    }
    merged_data =  select *, rowStd(temp3,temp6,temp9,temp12,temp15,temp18,temp21,temp24) as SD  from merged_data
    update merged_data set EarningsSurprise = EarningsSurprise/SD
    data = select * from SignalMasterTable left join merged_data on SignalMasterTable.permno = merged_data.permno and SignalMasterTable.time_avail_m  = merged_data.time_avail_m 
    data = select *, rank(mve_c)\count(*) as tempRK from data context by time_avail_m
    data = select * from data where tempRK >= 0.7 && !isNull(tempRK)
    result = select permno, time_avail_m,earnSupBig(permno, time_avail_m, mve_c, EarningsSurprise) as EarnSupBig from data where time_avail_m between startTime : endTime 
    return result
}
//prepareEarnSupBig(SignalMasterTable, m_QCompustat, 1986.03M, 2010.12M)




