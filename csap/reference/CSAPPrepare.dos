def prepareDivYield(CRSPdistributions, SignalMasterTable, startTime, endTime){
    data1 = select * from CRSPdistributions where !isNull(time_avail_m) and !isNull(divamt)
    data1 = select *, sum(divamt) as sum from data1 context by permno, time_avail_m
    merged_data = select permno, time_avail_m, mve_c, prc, divamt from SignalMasterTable left join data1 on SignalMasterTable.permno = data1.permno and SignalMasterTable.time_avail_m = data1.time_avail_m 
    result = select permno, time_avail_m,divYield(divamt, prc, time_avail_m, mve_c) as DivYield from merged_data
    return result
}
//prepareDivYield(CRSPdistributions, SignalMasterTable, 1986.03M, 2010.12M)
 


