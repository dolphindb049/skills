module CSAPPrepare
use CSAPFactors
//Predictors
def prepareAM(m_aCompustat, SignalMasterTable, startTime, endTime) {
    adjusted_table = select permno, time_avail_m, at, mve_c
    from m_aCompustat inner join SignalMasterTable on 
    SignalMasterTable.permno = m_aCompustat.permno and SignalMasterTable.time_avail_m = m_aCompustat.time_avail_m
    result = select permno, time_avail_m, am(at, mve_c) as am from adjusted_table where time_avail_m between startTime : endTime
    return result
}
//prepareAM(m_aCompustat, SignalMasterTable, 1986.03M, 2010.12M) 


def prepareAccruals(m_aCompustat, startTime, endTime) {
    // 使用 `context by` 分组并保留每组的第一条记录
    adjusted_table = select * from m_aCompustat context by permno, time_avail_m order by permno time_avail_m limit 1
    result = select permno, time_avail_m, accruals(txp, act, che, lct, dlc, dp, at) as accruals from adjusted_table where time_avail_m between startTime : endTime
    return result
}
//prepareAccruals(m_aCompustat, 1986.03M, 2010.12M) 


def prepareAccrualsBM(m_aCompustat, SignalMasterTable, startTime, endTime) {
    // 使用 `context by` 分组并保留每组的第一条记录
    adjusted_table = select * from m_aCompustat context by permno, time_avail_m order by permno time_avail_m limit 1
    adjusted_table = select adjusted_table.*, SignalMasterTable.mve_c 
    from adjusted_table inner join SignalMasterTable on 
    adjusted_table.permno = SignalMasterTable.permno and adjusted_table.time_avail_m = SignalMasterTable.time_avail_m

    result = select permno, time_avail_m, accrualsBM(permno,mve_c,time_avail_m,ceq,act,che,lct,dlc,txp,at) as accrualsbm from adjusted_table where time_avail_m between startTime : endTime
    return result
}
//prepareAccrualsBM(m_aCompustat,SignalMasterTable, 1986.03M, 2010.12M) 

def prepareAdExp(m_aCompustat, SignalMasterTable, startTime, endTime) {
    // 使用 `context by` 分组并保留每组的第一条记录
    adjusted_table = select m_aCompustat.*, SignalMasterTable.mve_c 
    from m_aCompustat inner join SignalMasterTable on 
    m_aCompustat.permno = SignalMasterTable.permno and m_aCompustat.time_avail_m = SignalMasterTable.time_avail_m
    result = select permno, time_avail_m, adExp(xad, mve_c) as AdExp from adjusted_table where time_avail_m between startTime : endTime
    return result
}
//prepareAdExp(m_aCompustat,SignalMasterTable, 1986.03M, 2010.12M) 



def prepareAssetGrowth(m_aCompustat, startTime, endTime) {
    result = select permno, time_avail_m,assetGrowth(at) as AssetGrowth from m_aCompustat where time_avail_m between startTime : endTime context by permno
    return result
}
//prepareAssetGrowth(m_aCompustat,1986.03M, 2010.12M) 



def prepareBM(m_aCompustat, SignalMasterTable, startTime, endTime) {
    mergedData = select m_aCompustat.*, SignalMasterTable.mve_c from m_aCompustat inner join SignalMasterTable on m_aCompustat.permno = SignalMasterTable.permno and  m_aCompustat.time_avail_m  = SignalMasterTable.time_avail_m 
    me_datadate = exec iif(move(mergedData.time_avail_m, 6) != (mergedData.datadate.year() * 12 + mergedData.datadate.month()), NULL,  move(mergedData.mve_c, 6)) from mergedData context by permno
    mergedData[`me_datadate] = me_datadate
    update mergedData set me_datadate = me_datadate.ffill()
    result = select permno, time_avail_m,bm(ceq, mve_c) as bm from mergedData where time_avail_m between startTime : endTime
    return result
}
//prepareBM(m_aCompustat,SignalMasterTable,1986.03M, 2010.12M) 


def prepareBMdec(m_aCompustat, monthlyCRSP, startTime, endTime) {
    mergedData = select permno, time_avail_m, txditc, seq, ceq, at, lt, pstk, pstkrv, pstkl, prc, shrout from m_aCompustat inner join monthlyCRSP on m_aCompustat.permno = monthlyCRSP.permno and  m_aCompustat.time_avail_m  = monthlyCRSP.time_avail_m 
    result = select permno, time_avail_m,bMdec(time_avail_m,txditc,seq,ceq,at,lt,pstk,pstkrv,pstkl,prc,shrout) as BMdec from mergedData where time_avail_m between startTime : endTime
    return result
}
//prepareBMdec(m_aCompustat,monthlyCRSP,1986.03M, 2010.12M) 



def prepareBeta(monthlyCRSP, monthlyFF, monthlyMarket, startTime, endTime) {
    mergedData = select permno, time_avail_m, ret, rf from monthlyCRSP inner join monthlyFF on monthlyCRSP.time_avail_m  = monthlyFF.time_avail_m 
    mergedData = select mergedData.*, monthlyMarket.ewretd from mergedData inner join monthlyMarket on mergedData.time_avail_m = monthlyMarket.time_avail_m
    result = select permno, time_avail_m,Beta(ret,ewretd,rf) as Beta from mergedData where time_avail_m between startTime : endTime
    return result
}
//prepareBeta(monthlyCRSP, monthlyFF, monthlyMarket,1986.03M, 2010.12M) 
 


def prepareBetaLiquidityPS(monthlyCRSP, monthlyFF, monthlyLiquidity, startTime, endTime) {
    mergedData = select permno, time_avail_m, ret, rf, mktrf, hml, smb from monthlyCRSP inner join monthlyFF on monthlyCRSP.time_avail_m  = monthlyFF.time_avail_m 
    mergedData = select * from mergedData left join monthlyLiquidity on mergedData.time_avail_m = monthlyLiquidity.time_avail_m
    result = select permno, time_avail_m,betaLiquidityPS(ret, ps_innov, rf) as BetaLiquidityPS from mergedData where time_avail_m between startTime : endTime
    return result
}
//prepareBetaLiquidityPS(monthlyCRSP, monthlyFF, monthlyLiquidity,1986.03M, 2010.12M) 
 


