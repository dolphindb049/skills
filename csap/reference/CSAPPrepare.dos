def prepareDivInit(CRSPdistributions, SignalMasterTable, startTime, endTime){
    data = select * from CRSPdistributions where !isNull(time_avail_m) && !isNull(divamt)
    sum_divamt = exec sum(divamt) from CRSPdistributions context by permno, time_avail_m
    update data set divamt = sum_divamt
    merged_data = select permno, time_avail_m, exchcd, shrcd, divamt from SignalMasterTable left join data on SignalMasterTable.permno = data.permno and SignalMasterTable.time_avail_m  = data.time_avail_m 
    result = select permno, time_avail_m, divInit(time_avail_m,exchcd,shrcd,divamt) as DivInit from merged_data where time_avail_m between startTime : endTime context by permno
    return result
}
//prepareDivInit(CRSPdistributions, SignalMasterTable, 1986.03M, 2010.12M)
 




def prepareDivOmit(CRSPdistributions, SignalMasterTable, startTime, endTime){
    data = select * from CRSPdistributions where !isNull(time_avail_m) && !isNull(divamt)
    sum_divamt = exec sum(divamt) from CRSPdistributions context by permno, time_avail_m
    update data set divamt = sum_divamt
    merged_data = select permno, time_avail_m, exchcd, shrcd, divamt from SignalMasterTable left join data on SignalMasterTable.permno = data.permno and SignalMasterTable.time_avail_m  = data.time_avail_m 
    result = select permno, time_avail_m, divOmit(time_avail_m,exchcd,shrcd,divamt) as DivOmit from merged_data where time_avail_m between startTime : endTime context by permno
    return result
}
//prepareDivOmit(CRSPdistributions, SignalMasterTable, 1986.03M, 2010.12M)
 



