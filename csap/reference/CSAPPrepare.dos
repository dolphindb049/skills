def prepareETR(m_aCompustat, startTime, endTime){
    m_aCompustat_update = m_aCompustat
    rename!(m_aCompustat_update, `pi, `pi0)
    result = select permno, time_avail_m,eTr(am, txt, pi0, epspx, ajex, prcc_f) as ETR from m_aCompustat_update where time_avail_m between startTime : endTime context by permno
    return result
