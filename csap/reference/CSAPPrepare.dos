    return result
}
//prepareCF(m_aCompustat, SignalMasterTable, 1986.03M, 2010.12M)
 



def prepareCash(m_QCompustat, SignalMasterTable, startTime, endTime) {
    data = select * from m_QCompustat context by gvkey, rdq having count(*) == 1 
    data = select * from data where(!isNull(gvkey) && !isNull(atq))
    data1 = data
    update data set time_avail_m = time_avail_m+1
    data2 = data
    update data set time_avail_m = time_avail_m+1
    data3 = data
    expandedData = data1.append!(data2).append!(data3)
    merged_data = select * from m_QCompustat context by gvkey, time_avail_m having count(*) == 1 order by gvkey, time_avail_m
    sig = select * from SignalMasterTable where !isNull(gvkey)
    merged_data = select permno, gvkey, time_avail_m, merged_data.atq, merged_data.cheq, merged_data.rdq from SignalMasterTable inner join merged_data on  SignalMasterTable.gvkey = merged_data.gvkey and SignalMasterTable.time_avail_m  = merged_data.time_avail_m 
    result = select permno, time_avail_m,cash(cheq, atq) as Cash from merged_data where time_avail_m between startTime : endTime
    return result
}
//prepareCash(m_QCompustat, SignalMasterTable,1986.03M, 2010.12M) 
 



