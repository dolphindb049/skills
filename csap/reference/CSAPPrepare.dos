def prepareZZ1_EarningsValueRelevance(monthlyCRSP, a_aCompustat, startTime, endTime){
    data1 = select permno, time_avail_m, ret, prc, shrout from monthlyCRSP
    update data1 set ret = nullFill(ret, 0)
    merged_data = select gvkey, datadate, fyear, ib, data1.* from a_aCompustat left join data1 on int(a_aCompustat.lpermno) = data1.permno and a_aCompustat.time_avail_m = data1.time_avail_m
    result = select permno, time_avail_m,zZ1EarningsValueRelevance(gvkey, permno, ret, prc, shrout, ib, time_avail_m) as ZZ1_EarningsValueRelevance from merged_data where time_avail_m between startTime : endTime
