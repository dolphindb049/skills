    defs = schema(tb).colDefs
    append!(probeTb, select curveRawDbPath as dbPath, "curve_shch_yield_raw" as tableName, long(rc) as rowCount, string(name) as colName, string(typeString) as colType, string(comment) as colComment, now() as probeTime from defs)
}

