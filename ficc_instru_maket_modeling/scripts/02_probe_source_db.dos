    tb = loadTable(rawDbPath, "std_field_mapping_instrument")
    rc = (exec count(*) from tb)[0]
    defs = schema(tb).colDefs
    append!(probeTb, select rawDbPath as dbPath, "std_field_mapping_instrument" as tableName, long(rc) as rowCount, string(name) as colName, string(typeString) as colType, string(comment) as colComment, now() as probeTime from defs)
}

if(existsTable(curveRawDbPath, "std_field_mapping_marketdata")){
    tb = loadTable(curveRawDbPath, "std_field_mapping_marketdata")
    rc = (exec count(*) from tb)[0]
    defs = schema(tb).colDefs
    append!(probeTb, select curveRawDbPath as dbPath, "std_field_mapping_marketdata" as tableName, long(rc) as rowCount, string(name) as colName, string(typeString) as colType, string(comment) as colComment, now() as probeTime from defs)
}

if(existsTable(instDbPath, "Instrument")){
    tb = loadTable(instDbPath, "Instrument")
    rc = (exec count(*) from tb)[0]
    defs = schema(tb).colDefs
    append!(probeTb, select instDbPath as dbPath, "Instrument" as tableName, long(rc) as rowCount, string(name) as colName, string(typeString) as colType, string(comment) as colComment, now() as probeTime from defs)
}

if(existsTable(mdDbPath, "MarketData")){
    tb = loadTable(mdDbPath, "MarketData")
    rc = (exec count(*) from tb)[0]
    defs = schema(tb).colDefs
    append!(probeTb, select mdDbPath as dbPath, "MarketData" as tableName, long(rc) as rowCount, string(name) as colName, string(typeString) as colType, string(comment) as colComment, now() as probeTime from defs)
}

select dbPath, tableName, max(rowCount) as rowCount, count(*) as colCount
from std_probe_report
group by dbPath, tableName
order by dbPath, tableName

print("[OK] source probe passed on current node. expected endpoint=" + expectedEndpoint)
